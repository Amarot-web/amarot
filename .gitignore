# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# documentación interna (archivos antiguos)
/docs/DIAGNOSTICO-WEB.md
/docs/diagnostico-web-amarot.md
/docs/PLAN-WEB.md
Antecedentes.md
Claude.md
planSEO.md

# archivos de análisis
*.xlsx
*.html

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/

# supabase temp
supabase/.temp/
supabase/.branches/

# archivos de migración (generados para entrega, no commitear)
supabase/export/
supabase/*.zip

# entorno de desarrollo local (NO se versiona ni se sube a prod — ver dev-local)
# Estos archivos viven solo en disco para correr Supabase local; main = producción.
supabase/config.toml
supabase/seed.sql
supabase/baseline.local.sql
scripts/db-env.sh
